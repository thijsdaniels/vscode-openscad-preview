{
  "name": "vscode-openscad-preview",
  "displayName": "OpenSCAD Preview",
  "description": "An interactive 3D preview environment for OpenSCAD (.scad) files.",
  "publisher": "thijsdaniels",
  "version": "0.5.0",
  "icon": "icon.png",
  "author": "Thijs Daniels",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thijsdaniels/vscode-openscad-preview.git"
  },
  "type": "module",
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node ./esbuild.ts",
    "package": "NODE_ENV=production node ./esbuild.ts",
    "watch": "npm run compile -- --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "types": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "node ./dist/test/runTest.js",
    "update": "npx npm-check-updates@latest -u -i"
  },
  "extensionPack": [
    "Leathong.openscad-language-support"
  ],
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@vscode-elements/elements": "^2.5.1",
    "@vscode/codicons": "^0.0.44",
    "chokidar": "^5.0.0",
    "lit": "^3.3.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.x",
    "@types/three": "^0.183.1",
    "@types/vscode": "^1.105.1",
    "@types/vscode-webview": "^1.57.5",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vscode-test": "^1.6.1"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "contributes": {
    "configuration": {
      "title": "OpenSCAD",
      "properties": {
        "openscad.previewFormat": {
          "type": "string",
          "enum": [
            "3mf",
            "stl"
          ],
          "default": "3mf",
          "description": "The format to use for the 3D preview. 3MF supports colors but requires OpenSCAD Nightly. STL is universally supported."
        },
        "openscad.slicerExecutable": {
          "type": "string",
          "default": "",
          "description": "Optional path to the slicer executable (e.g., Bambu Studio or PrusaSlicer). If left empty, the OS default application for the 3D model will be used."
        },
        "openscad.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the OpenSCAD executable. Leave empty to use automatic detection or the system PATH."
        }
      }
    },
    "commands": [
      {
        "command": "openscad.showPanel",
        "title": "Show OpenSCAD Preview",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "openscad.showPanel",
          "group": "navigation",
          "when": "resourceLangId == scad || editorLangId == scad"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openscad.showPanel",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == scad"
      }
    ],
    "languages": [
      {
        "id": "scad",
        "extensions": [
          ".scad"
        ],
        "aliases": [
          "OpenSCAD"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "scad",
        "scopeName": "source.scad",
        "path": "./syntaxes/scad.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "scad",
        "path": "./snippets/scad.snippets.json"
      }
    ]
  },
  "main": "./dist/extension.cjs",
  "files": [
    "dist",
    "docs",
    "snippets",
    "syntaxes",
    "language-configuration.json",
    "icon.png",
    "LICENSE.md",
    "CHANGELOG.md",
    "node_modules/@vscode/codicons/dist"
  ]
}
